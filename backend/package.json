{
    "name": "@skill-sync/backend",
    "version": "1.0.0",
    "private": true,
    "main": "src/server.ts",
    "scripts": {
        "start": "ts-node src/server.ts",
        "dev": "nodemon --exec ts-node src/server.ts",
        "check-user": "ts-node src/utils/check_user.js",
        "generate": "prisma generate --schema=../database/prisma/schema.prisma",
        "push": "prisma db push --schema=../database/prisma/schema.prisma"
    },
    "dependencies": {
        "@google/generative-ai": "^0.1.0",
        "@prisma/client": "^6.2.0",
        "axios": "^1.13.6",
        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "express": "^4.18.2",
        "firebase": "^12.9.0",
        "firebase-admin": "^11.11.1",
        "node-cron": "^4.2.1",
        "prisma": "^6.2.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/node": "^20.0.0",
        "nodemon": "^3.0.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.6"
    }
}
